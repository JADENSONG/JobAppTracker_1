# Copy this to .env for local testing (do NOT commit the real .env file).
# python-dotenv isn't wired in by default — for local runs, export these
# in your shell instead, e.g. `export ANTHROPIC_API_KEY=sk-ant-...`

# Anthropic API key from console.anthropic.com (NOT your Claude.ai subscription)
ANTHROPIC_API_KEY=sk-ant-...

# The full raw contents of your Google service account JSON file, as one line
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","...":"..."}

# From your Google Sheet's URL
SHEET_ID=1gS_fNj0PPG-d2no5WbNAp5BGV3AtOiB6xxxX5C2UmHo
SHEET_TAB=Sheet1

# A password you make up — required in the app to log a job
APP_PASSWORD=changeme
